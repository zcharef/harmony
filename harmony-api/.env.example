# Harmony API — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── Server ──────────────────────────────────────────────
SERVER_PORT=3000
ENVIRONMENT=development

# ── Database (Supabase Postgres) ────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres

# ── Auth (Supabase JWT) ────────────────────────────────
# Get from: supabase status (local) or Supabase Dashboard > Settings > API
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://127.0.0.1:64321

# ── Plan enforcement (disable for self-hosted) ──────────
# Set to false for self-hosted instances to remove all SaaS plan limits.
PLAN_ENFORCEMENT_ENABLED=false

# ── Anti-abuse SpamGuard (flood auto-mute, duplicate + rate limits) ──
# Default true. Set false for E2E suites (high-volume message seeding trips
# the flood mute) and single-user self-hosted instances.
# SPAM_GUARD_ENABLED=false

# ── Trusted proxy (optional — invite OG Pages Function) ──────────────
# Shared secret letting the Cloudflare Pages Function forward the original
# client IP (x-harmony-client-ip) for unauth rate limiting. Must match the
# HARMONY_PROXY_SECRET env var on the Pages project. Unset = header ignored.
# TRUSTED_PROXY_SECRET=

# ── Observability (optional) ────────────────────────────
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=harmony-api

# ── Official server (optional — leave unset for self-hosted) ─────────
# UUID of the official Harmony server. New users are auto-joined on signup.
# OFFICIAL_SERVER_ID=

# ── LiveKit Voice (optional — leave unset to disable voice) ──────────
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# ── Klipy GIF picker (optional — leave unset to disable the GIF picker) ─
# Server-side only. When unset, /v1/gifs/* return 503 and the client hides
# the GIF button. NEVER expose this as a VITE_ variable — the key must not
# reach the browser (every Klipy call is proxied through the Rust API).
# KLIPY_API_KEY=
# Process-global cap on upstream Klipy calls per rolling hour (default 90,
# safely under the test key's 100/hr). Raise/disable for the production key.
# KLIPY_GLOBAL_MAX_PER_HOUR=90
