# Harmony API — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── Server ──────────────────────────────────────────────
SERVER_PORT=3000
ENVIRONMENT=development

# ── Database (Supabase Postgres) ────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres

# ── Auth (Supabase JWT) ────────────────────────────────
# Get from: supabase status (local) or Supabase Dashboard > Settings > API
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL=http://127.0.0.1:64321

# ── Plan enforcement (disable for self-hosted) ──────────
# Set to false for self-hosted instances to remove all SaaS plan limits.
PLAN_ENFORCEMENT_ENABLED=false

# ── Rate limiting ────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Observability (optional) ────────────────────────────
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=harmony-api

# ── LiveKit Voice (optional — leave unset to disable voice) ──────────
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
