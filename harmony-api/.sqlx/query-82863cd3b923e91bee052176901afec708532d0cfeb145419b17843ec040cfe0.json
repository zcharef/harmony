  "db_name": "PostgreSQL",
  "query": "\n            UPDATE profiles\n            SET\n                avatar_url = COALESCE($2, avatar_url),\n                display_name = COALESCE($3, display_name),\n                custom_status = COALESCE($4, custom_status),\n                updated_at = now()\n            WHERE id = $1\n            RETURNING\n                id,\n                username,\n                display_name,\n                avatar_url,\n                status,\n                custom_status,\n                created_at,\n                updated_at\n            ",
