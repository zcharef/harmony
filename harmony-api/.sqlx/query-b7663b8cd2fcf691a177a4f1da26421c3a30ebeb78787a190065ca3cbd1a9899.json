{
  "db_name": "PostgreSQL",
  "query": "\n            INSERT INTO profiles (id, username, status, display_name)\n            VALUES ($1, $2, $3, $4)\n            ON CONFLICT (id) DO UPDATE\n                SET id = profiles.id\n            RETURNING\n                id,\n                username,\n                display_name,\n                avatar_url,\n                status,\n                custom_status,\n                bio,\n                banner_url,\n                EXISTS(\n                    SELECT 1 FROM user_badges ub\n                    WHERE ub.user_id = profiles.id AND ub.badge = 'founding'\n                ) AS \"is_founding!\",\n                created_at,\n                updated_at\n            ",
