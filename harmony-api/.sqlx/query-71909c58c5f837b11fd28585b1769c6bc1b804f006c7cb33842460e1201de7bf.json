  "query": "\n            SELECT\n                id,\n                server_id,\n                name,\n                topic,\n                channel_type as \"channel_type!: String\",\n                position,\n                is_private,\n                is_read_only,\n                encrypted,\n                created_at,\n                updated_at\n            FROM channels\n            WHERE server_id = $1\n            ORDER BY position ASC\n            LIMIT 1\n            ",
