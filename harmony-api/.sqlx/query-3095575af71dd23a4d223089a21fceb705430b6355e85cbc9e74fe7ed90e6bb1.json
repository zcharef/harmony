{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT sb.server_id, sb.user_id, p.username, p.avatar_url,\n                   sb.banned_by, sb.reason, sb.created_at\n            FROM server_bans sb\n            INNER JOIN profiles p ON p.id = sb.user_id\n            WHERE sb.server_id = $1\n            ORDER BY sb.created_at DESC\n            ",
