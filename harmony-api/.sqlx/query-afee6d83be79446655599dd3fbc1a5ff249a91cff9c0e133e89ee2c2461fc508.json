{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                channel_id,\n                author_id,\n                content,\n                edited_at,\n                deleted_at,\n                deleted_by,\n                encrypted,\n                sender_device_id,\n                created_at\n            FROM messages\n            WHERE channel_id = $1\n              AND deleted_at IS NULL\n              AND ($2::timestamptz IS NULL OR created_at < $2)\n            ORDER BY created_at DESC\n            LIMIT $3\n            ",
