{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                user_id,\n                device_id,\n                key_id,\n                public_key,\n                is_fallback,\n                created_at\n            FROM one_time_keys\n            WHERE user_id = $1\n              AND device_id = $2\n              AND is_fallback = true\n            ORDER BY created_at DESC\n            LIMIT 1\n            ",
