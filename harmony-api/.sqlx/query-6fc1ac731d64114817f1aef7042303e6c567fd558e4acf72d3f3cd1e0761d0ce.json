  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                username,\n                display_name,\n                avatar_url,\n                status,\n                custom_status,\n                bio,\n                banner_url,\n                EXISTS(\n                    SELECT 1 FROM user_badges ub\n                    WHERE ub.user_id = profiles.id AND ub.badge = 'founding'\n                ) AS \"is_founding!\",\n                created_at,\n                updated_at\n            FROM profiles\n            WHERE id = $1\n            ",
