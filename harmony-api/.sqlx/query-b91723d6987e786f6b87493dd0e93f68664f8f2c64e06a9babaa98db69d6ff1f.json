{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                p.id AS \"id!\",\n                p.username AS \"username!\",\n                p.display_name,\n                sm.nickname\n            FROM profiles p\n            LEFT JOIN server_members sm\n                ON sm.user_id = p.id AND sm.server_id = $1\n            WHERE p.id = ANY($2)\n            ",
