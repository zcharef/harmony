  "query": "\n            SELECT server_id, user_id, banned_by, reason, created_at\n            FROM server_bans\n            WHERE server_id = $1\n              AND ($2::timestamptz IS NULL OR created_at < $2)\n            ORDER BY created_at DESC\n            LIMIT $3\n            ",
