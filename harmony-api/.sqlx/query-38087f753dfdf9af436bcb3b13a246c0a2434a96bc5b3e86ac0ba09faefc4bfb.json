{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                s.id,\n                s.name,\n                s.icon_url,\n                s.owner_id,\n                s.is_dm,\n                s.created_at,\n                s.updated_at\n            FROM servers s\n            INNER JOIN server_members sm ON sm.server_id = s.id\n            WHERE sm.user_id = $1\n              AND s.is_dm = false\n            ORDER BY s.created_at\n            ",
