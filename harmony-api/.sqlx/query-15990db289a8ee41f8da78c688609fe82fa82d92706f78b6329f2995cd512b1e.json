  "query": "\n            UPDATE messages\n            SET content = $2, is_edited = true, edited_at = now()\n            WHERE id = $1 AND deleted_at IS NULL\n            RETURNING\n                id,\n                channel_id,\n                author_id,\n                content,\n                edited_at,\n                deleted_at,\n                deleted_by,\n                encrypted,\n                sender_device_id,\n                created_at\n            ",
