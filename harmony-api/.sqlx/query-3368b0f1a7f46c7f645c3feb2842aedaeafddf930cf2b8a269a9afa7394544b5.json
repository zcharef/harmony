{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                sm.user_id,\n                sm.server_id,\n                p.username,\n                p.avatar_url,\n                sm.nickname,\n                sm.role as \"role!\",\n                sm.joined_at\n            FROM server_members sm\n            INNER JOIN profiles p ON p.id = sm.user_id\n            WHERE sm.server_id = $1 AND sm.user_id = $2\n            ",
