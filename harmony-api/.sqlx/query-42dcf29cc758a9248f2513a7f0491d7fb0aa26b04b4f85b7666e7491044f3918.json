{
  "db_name": "PostgreSQL",
  "query": "\n            INSERT INTO profiles (id, username, status)\n            VALUES ($1, $2, $3)\n            ON CONFLICT (id) DO UPDATE\n                SET username = EXCLUDED.username,\n                    updated_at = now()\n            RETURNING\n                id,\n                username,\n                display_name,\n                avatar_url,\n                status,\n                custom_status,\n                created_at,\n                updated_at\n            ",
