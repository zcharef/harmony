{
  "openapi": "3.1.0",
  "info": {
    "title": "Harmony API",
    "description": "REST API for Harmony.\n\n**Rate Limiting:** All endpoints are subject to rate limiting. When the limit is exceeded, the API responds with `429 Too Many Requests` and a `Retry-After` header indicating when the client may retry.",
    "license": {
      "name": "AGPL-3.0"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Deep health check endpoint.",
        "operationId": "health_check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service degraded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ComponentHealth": {
        "type": "object",
        "description": "Health status of individual components.",
        "required": [
          "database",
          "api"
        ],
        "properties": {
          "api": {
            "type": "string",
            "description": "API server status (always \"operational\" if responding)"
          },
          "database": {
            "type": "string",
            "description": "Database connectivity: \"connected\", \"disconnected\", or error detail"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "description": "Deep health check response with component status.",
        "required": [
          "status",
          "components",
          "latency_ms",
          "version"
        ],
        "properties": {
          "components": {
            "$ref": "#/components/schemas/ComponentHealth",
            "description": "Individual component health"
          },
          "latency_ms": {
            "type": "integer",
            "format": "int64",
            "description": "Time taken for health check in milliseconds",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "description": "Overall service status: \"up\" or \"down\""
          },
          "version": {
            "type": "string",
            "description": "API version from Cargo.toml"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "description": "RFC 9457 Problem Details response.\n\nAll API errors are returned in this standardized format.",
        "required": [
          "type",
          "title",
          "status",
          "detail"
        ],
        "properties": {
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase JWT (mobile/API clients)"
      }
    }
  },
  "tags": [
    {
      "name": "System",
      "description": "System health and status endpoints"
    }
  ]
}
