# Harmony App — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ── Rust REST API ─────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ── Supabase (Auth + Realtime + Storage) ──────────────
# Get from: supabase status (local) or Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=http://127.0.0.1:64321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# ── Cloudflare Turnstile (Bot Protection) ─────────────
# Test key that always passes — safe for local dev.
# For production (SaaS): https://dash.cloudflare.com → Turnstile → Add Widget
# Optional for self-hosted: leave unset to skip bot protection entirely.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ── Official Harmony Server (optional) ─────────────
# Server ID for the official community server (auto-joined on signup).
# Excluded from onboarding "has servers" check so welcome screen still shows.
# VITE_OFFICIAL_SERVER_ID=

# ── Desktop Auth (Tauri only, optional) ──────────────
# URL of the web app — used by Tauri to open the login page in the system browser.
# In production: https://app.joinharmony.app — in dev: http://localhost:1420
# VITE_WEB_APP_URL=http://localhost:1420

# ── Sentry (optional, crash reporting) ───────────────
# VITE_SENTRY_DSN=
