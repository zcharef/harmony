{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/main.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/lib/api/**"],
  "commitlint": {
    "config": ["commitlint.config.js"]
  },
  "rules": {
    "files": "warn",
    "dependencies": "error",
    "unlisted": "warn",
    "exports": "warn",
    "types": "warn"
  },
  "ignoreDependencies": ["@commitlint/cli", "tailwindcss", "@hey-api/client-fetch", "jsdom"]
}
