{
  "name": "harmony-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:boundaries": "eslint --config eslint.config.mjs src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:arch": "vitest run --config vitest.config.arch.ts",
    "circular": "madge --circular --extensions ts,tsx src/",
    "knip": "knip",
    "gen:api": "openapi-ts",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/nunito": "^5.2.7",
    "@heroui/react": "^3.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.4.2",
    "@sentry/browser": "^10.46.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "clsx": "^2.1.1",
    "i18next": "^25.10.4",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^16.6.1",
    "react-resizable-panels": "^4.7.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@hey-api/openapi-ts": "^0.94.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "jsdom": "^28.1.0",
    "knip": "^5.88.1",
    "madge": "^8.0.0",
    "tailwindcss": "4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0"
    }
  }
}
