{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harmony",
  "version": "0.1.7",
  "identifier": "app.harmony",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Harmony — Alpha",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: https:; connect-src 'self' http://localhost:* http://127.0.0.1:* https://*.supabase.co wss://*.supabase.co https://*.sentry.io https://* wss://* ipc://localhost; frame-src https://challenges.cloudflare.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["harmony"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3NTYyM0ExMjIxRUIzREYKUldUZnN4NGlvU05XdDNnMUFZWjUzLyszNG55NTBPVmdRTm95SlhhNnJOeEw0Z3pVcks1MW9qMUIK",
      "endpoints": [
        "https://github.com/zcharef/harmony/releases/latest/download/latest.json"
      ]
    }
  }
}
